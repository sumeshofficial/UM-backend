PORT=3000

POSTGRES_URL=postgresql://postgres:password@localhost:5432/um_backend
MONGODB_URL=mongodb://localhost:27017/um_backend

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

BULLMQ_ATTEMPTS=3
BULLMQ_BACKOFF_DELAY=1000

BULLMQ_REMOVE_ON_COMPLETE=100
BULLMQ_REMOVE_ON_FAIL=50

JWT_EXPIRES_IN=1d
JWT_SECRET=um_backend_secret